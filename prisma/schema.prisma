generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String        @id @default(cuid())
  email                String        @unique
  name                 String?
  image                String?
  lsCustomerId         String?       @unique
  subscriptionStatus   String?       // active | on_trial | paused | past_due | cancelled | expired | null
  subscriptionVariantId String?
  subscriptionEndsAt   DateTime?
  createdAt            DateTime      @default(now())
  generations          Generation[]
}

model Generation {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt         String
  negativePrompt String?
  loraId         String
  loraName       String?
  steps          Int?
  imageUrl       String
  createdAt      DateTime @default(now())
}
