# Universal: any Postgres URL works (Vercel Postgres, Neon, Supabase, Railway, Render, self-hosted)
# Example: postgresql://user:password@host:5432/lorahub?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/lorahub"
SESSION_SECRET="change-me-to-a-long-random-string"
# Optional GitHub OAuth (dev email login works without it)
GITHUB_ID=""
GITHUB_SECRET=""
# Replicate (leave empty to use mock image generation)
REPLICATE_API_TOKEN=""
# Lemon Squeezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_SIGNING_SECRET=""
LEMONSQUEEZY_PRO_VARIANT_ID=""
LEMONSQUEEZY_PRO_PRICE_LABEL="$12/mo"
APP_URL="http://localhost:3000"
